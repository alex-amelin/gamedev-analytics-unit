# Креды Яндекс Метрики этого хранилища игры.
# Скопируй файл в `.env` и впиши значения. Образец `.env.example` КОММИТИТСЯ;
# реальный `.env` с секретами — НЕ коммитится (он в `.gitignore`).
# Креды не публикуй и не выводи в лог.

# OAuth-токен Яндекс Метрики (Logs API).
YANDEX_METRICA_TOKEN=

# Числовой идентификатор счётчика Метрики этой игры.
YANDEX_METRICA_COUNTER_ID=

# Корень хранилища (абсолютный путь к этой папке игры). Обычно проставляет
# `gdau-init` при развороте; вручную фиксировать не нужно — абсолютный путь
# не переносится между машинами. Раскомментируй только при необходимости.
# GDAU_DATA_ROOT=
